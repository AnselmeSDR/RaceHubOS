generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Driver {
  id                String             @id @default(cuid())
  name              String
  email             String?            @unique
  img               String?
  color             String             @default("#3B82F6")
  teamId            String?
  totalRaces        Int                @default(0)
  wins              Int                @default(0)
  podiums           Int                @default(0)
  bestLap           Float?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  number            Int?               @unique
  team              Team?              @relation(fields: [teamId], references: [id])
  laps              Lap[]
  sessions          SessionDriver[]
  controllerConfigs      ControllerConfig[]
  trackRecords           TrackRecord[]
  championshipParticipants ChampionshipParticipant[]
}

model Car {
  id                String             @id @default(cuid())
  brand             String
  model             String
  year              Int?
  img               String?
  color             String             @default("#3B82F6")
  maxSpeed          Int                @default(100)
  brakeForce        Int                @default(50)
  fuelCapacity      Int                @default(100)
  totalRaces        Int                @default(0)
  bestLap           Float?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  laps                     Lap[]
  sessions                 SessionDriver[]
  controllerConfigs        ControllerConfig[]
  trackRecords             TrackRecord[]
}

model Track {
  id                String             @id @default(cuid())
  name              String
  img               String?
  layout            String?
  length            Float?
  corners           Int?
  color             String             @default("#9333ea")
  bestLap           Float?
  bestLapBy         String?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  controllerConfigs ControllerConfig[]
  trackRecords      TrackRecord[]
  laps              Lap[]
  championships     Championship[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  color     String?
  img       String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drivers   Driver[]
}

model Championship {
  id                String                   @id @default(cuid())
  name              String
  season            String
  status            String                   @default("planned")
  trackId           String?
  mode              String                   @default("manual") // "manual" | "auto"
  driversPerQualif  Int?                     // 2-6, only for auto mode
  driversPerRace    Int?                     // 2-6, only for auto mode
  qualifMaxDuration Int?                     // ms, shared config for all qualif sessions
  qualifMaxLaps     Int?
  raceMaxDuration   Int?                     // ms, shared config for all race sessions
  raceMaxLaps       Int?
  deletedAt         DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  sessions          Session[]
  participants      ChampionshipParticipant[]
  track             Track?                   @relation(fields: [trackId], references: [id])
}

model Session {
  id             String          @id @default(cuid())
  name           String?
  type           String
  trackId        String
  championshipId String?
  fuelMode       String          @default("OFF")
  status         String          @default("draft") // draft, ready, active, finishing, finished
  maxDuration    Int?            // Session max duration in ms
  maxLaps        Int?
  gracePeriod    Int?            // Grace period after leader finishes (ms), default 30000
  pauses         String?         // JSON: [{ start: timestamp, end: timestamp | null }]
  startedAt      DateTime?
  finishingAt    DateTime?       // When grace period started
  finishedAt     DateTime?
  deletedAt      DateTime?
  syncedAt       DateTime?
  cuVersion      String?
  cuFuelMode     Boolean?
  cuRealMode     Boolean?
  cuPitLane      Boolean?
  cuLapCounter   Boolean?
  cuNumCars      Int?
  order          Int             @default(0)       // Display order within championship
  autoGroup      Int?                              // Group index for auto championships
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  laps           Lap[]
  championship   Championship?   @relation(fields: [championshipId], references: [id])
  track          Track           @relation(fields: [trackId], references: [id])
  drivers        SessionDriver[]
  trackRecords   TrackRecord[]
}

model SessionDriver {
  id              String   @id @default(cuid())
  sessionId       String
  driverId        String?  // Optional for draft configs
  carId           String?  // Optional for draft configs
  controller      Int      // 0-5 (CU address)
  position        Int?
  gridPos         Int?
  finalPos        Int?
  lapsAtFinishing Int?     // Snapshot of laps when grace period started
  totalLaps       Int      @default(0)
  totalTime       Int      @default(0) // ms
  bestLapTime     Int?     // Best lap time in ms
  lastLapTime     Int?     // Last lap time in ms
  isDNF           Boolean  @default(false)
  deletedAt       DateTime?
  car             Car?     @relation(fields: [carId], references: [id])
  driver          Driver?  @relation(fields: [driverId], references: [id])
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, controller])
}

model Lap {
  id            String    @id @default(cuid())
  sessionId     String
  trackId       String
  driverId      String?
  carId         String
  controller    Int       // 0-5 (CU address)
  phase         String
  lapNumber     Int
  lapTime       Float
  sector1       Float?
  sector2       Float?
  sector3       Float?
  deletedAt     DateTime?
  timestamp     DateTime  @default(now())
  car           Car       @relation(fields: [carId], references: [id])
  driver        Driver?   @relation(fields: [driverId], references: [id])
  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  track         Track     @relation(fields: [trackId], references: [id])

  @@index([sessionId, driverId])
  @@index([sessionId, lapTime])
  @@index([sessionId, phase])
  @@index([sessionId, deletedAt])
  @@index([trackId, driverId, lapTime])
}


model ControllerConfig {
  id         String   @id @default(cuid())
  controller Int      // 0-5 (CU address)
  driverId   String?
  carId      String?
  trackId    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  driver Driver? @relation(fields: [driverId], references: [id])
  car    Car?    @relation(fields: [carId], references: [id])
  track  Track   @relation(fields: [trackId], references: [id])

  @@unique([trackId, controller])
}

model TrackRecord {
  id        String   @id @default(cuid())
  trackId   String
  driverId  String
  carId     String
  lapTime   Float
  sessionId String?
  deletedAt DateTime?
  setAt     DateTime @default(now())

  track   Track    @relation(fields: [trackId], references: [id])
  driver  Driver   @relation(fields: [driverId], references: [id])
  car     Car      @relation(fields: [carId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([trackId, driverId, carId])
}

model ChampionshipParticipant {
  id             String       @id @default(cuid())
  championshipId String
  driverId       String
  order          Int          @default(0)
  createdAt      DateTime     @default(now())

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  driver       Driver       @relation(fields: [driverId], references: [id])

  @@unique([championshipId, driverId])
}

model Device {
  id            String    @id @default(cuid())
  address       String    @unique
  name          String
  type          String    @default("cu") // simulator | cu
  lastConnected DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Preference {
  key       String   @id
  value     String   // JSON
  updatedAt DateTime @updatedAt
}
