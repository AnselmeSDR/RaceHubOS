generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Driver {
  id                String             @id @default(cuid())
  name              String
  email             String?            @unique
  photo             String?
  color             String             @default("#3B82F6")
  teamId            String?
  totalRaces        Int                @default(0)
  wins              Int                @default(0)
  podiums           Int                @default(0)
  bestLap           Float?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  number            Int?               @unique
  team              Team?              @relation(fields: [teamId], references: [id])
  laps              Lap[]
  sessions          SessionDriver[]
  controllerConfigs ControllerConfig[]
  trackRecords      TrackRecord[]
}

model Car {
  id                String             @id @default(cuid())
  brand             String
  model             String
  year              Int?
  photo             String?
  color             String             @default("#3B82F6")
  maxSpeed          Int                @default(100)
  brakeForce        Int                @default(50)
  fuelCapacity      Int                @default(100)
  totalRaces        Int                @default(0)
  bestLap           Float?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  laps              Lap[]
  sessions          SessionDriver[]
  controllerConfigs ControllerConfig[]
  trackRecords      TrackRecord[]
}

model Track {
  id                String             @id @default(cuid())
  name              String
  photo             String?
  layout            String?
  length            Float?
  corners           Int?
  color             String             @default("#9333ea")
  bestLap           Float?
  bestLapBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  controllerConfigs ControllerConfig[]
  trackRecords      TrackRecord[]
  laps              Lap[]
  championships     Championship[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  color     String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drivers   Driver[]
}

model Championship {
  id           String                 @id @default(cuid())
  name         String
  season       String
  pointsSystem String
  status       String                 @default("planned")
  trackId      String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  standings    ChampionshipStanding[]
  sessions     Session[]
  track        Track?                 @relation(fields: [trackId], references: [id])
}

model ChampionshipStanding {
  id             String       @id @default(cuid())
  championshipId String
  driverId       String
  position       Int
  points         Int          @default(0)
  wins           Int          @default(0)
  podiums        Int          @default(0)
  qualifBestTime Int?
  raceTotalLaps  Int          @default(0)
  raceTotalTime  Int          @default(0)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@unique([championshipId, driverId])
}

model Session {
  id             String          @id @default(cuid())
  name           String?
  type           String
  trackId        String
  championshipId String?
  fuelMode       String          @default("OFF")
  status         String          @default("draft") // draft, ready, active, finishing, finished
  duration       Int?            // Session duration in ms
  maxLaps        Int?
  gracePeriod    Int?            // Grace period after leader finishes (ms), default 30000
  startedAt      DateTime?
  finishingAt    DateTime?       // When grace period started
  finishedAt     DateTime?
  syncedAt       DateTime?
  cuVersion      String?
  cuFuelMode     Boolean?
  cuRealMode     Boolean?
  cuPitLane      Boolean?
  cuLapCounter   Boolean?
  cuNumCars      Int?
  order          Int             @default(0)       // Display order within championship
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  laps           Lap[]
  events         RaceEvent[]
  championship   Championship?   @relation(fields: [championshipId], references: [id])
  track          Track           @relation(fields: [trackId], references: [id])
  drivers        SessionDriver[]
  phases         SessionPhase[]
  trackRecords   TrackRecord[]
}

model SessionPhase {
  id         String    @id @default(cuid())
  sessionId  String
  phase      String
  status     String    @default("waiting")
  duration   Int?
  maxLaps    Int?
  startedAt  DateTime?
  pausedAt   DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, phase])
}

model SessionDriver {
  id              String   @id @default(cuid())
  sessionId       String
  driverId        String
  carId           String
  controller      Int      // 0-5 (CU address)
  position        Int?
  gridPos         Int?
  finalPos        Int?
  lapsAtFinishing Int?     // Snapshot of laps when grace period started
  totalLaps       Int      @default(0)
  totalTime       Int      @default(0) // ms
  bestLapTime     Int?     // Best lap time in ms
  lastLapTime     Int?     // Last lap time in ms
  isDNF           Boolean  @default(false)
  car             Car      @relation(fields: [carId], references: [id])
  driver          Driver   @relation(fields: [driverId], references: [id])
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, driverId])
  @@unique([sessionId, controller])
}

model Lap {
  id            String    @id @default(cuid())
  sessionId     String
  trackId       String
  driverId      String
  carId         String
  controller    Int       // 0-5 (CU address)
  phase         String
  lapNumber     Int
  lapTime       Float
  sector1       Float?
  sector2       Float?
  sector3       Float?
  softDeletedAt DateTime? // For practice reset (null = active)
  timestamp     DateTime  @default(now())
  car           Car       @relation(fields: [carId], references: [id])
  driver        Driver    @relation(fields: [driverId], references: [id])
  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  track         Track     @relation(fields: [trackId], references: [id])

  @@index([sessionId, driverId])
  @@index([sessionId, lapTime])
  @@index([sessionId, phase])
  @@index([sessionId, softDeletedAt])
  @@index([trackId, driverId, lapTime])
}

model RaceEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  data      String
  timestamp DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}

model ControllerConfig {
  id         String   @id @default(cuid())
  controller Int      // 0-5 (CU address)
  driverId   String?
  carId      String?
  trackId    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  driver Driver? @relation(fields: [driverId], references: [id])
  car    Car?    @relation(fields: [carId], references: [id])
  track  Track   @relation(fields: [trackId], references: [id])

  @@unique([trackId, controller])
}

model TrackRecord {
  id        String   @id @default(cuid())
  trackId   String
  driverId  String
  carId     String
  lapTime   Float
  sessionId String?
  setAt     DateTime @default(now())

  track   Track    @relation(fields: [trackId], references: [id])
  driver  Driver   @relation(fields: [driverId], references: [id])
  car     Car      @relation(fields: [carId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([trackId, driverId, carId])
}
