generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Driver {
  id         String          @id @default(cuid())
  name       String
  email      String?         @unique
  photo      String?
  color      String          @default("#3B82F6")
  teamId     String?
  totalRaces Int             @default(0)
  wins       Int             @default(0)
  podiums    Int             @default(0)
  bestLap    Float?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  number     Int?            @unique
  team       Team?           @relation(fields: [teamId], references: [id])
  laps       Lap[]
  sessions   SessionDriver[]
}

model Car {
  id           String          @id @default(cuid())
  brand        String
  model        String
  year         Int?
  photo        String?
  color        String          @default("#3B82F6")
  maxSpeed     Int             @default(100)
  brakeForce   Int             @default(50)
  fuelCapacity Int             @default(100)
  totalRaces   Int             @default(0)
  bestLap      Float?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  laps         Lap[]
  sessions     SessionDriver[]
}

model Track {
  id        String    @id @default(cuid())
  name      String
  photo     String?
  layout    String?
  length    Float?
  corners   Int?
  color     String    @default("#9333ea")
  bestLap   Float?
  bestLapBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  color     String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drivers   Driver[]
}

model Championship {
  id           String                 @id @default(cuid())
  name         String
  season       String
  pointsSystem String
  status       String                 @default("planned")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  standings    ChampionshipStanding[]
  sessions     Session[]
}

model ChampionshipStanding {
  id             String       @id @default(cuid())
  championshipId String
  driverId       String
  position       Int
  points         Int          @default(0)
  wins           Int          @default(0)
  podiums        Int          @default(0)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@unique([championshipId, driverId])
}

model Session {
  id             String          @id @default(cuid())
  name           String?
  type           String
  trackId        String
  championshipId String?
  fuelMode       String          @default("OFF")
  status         String          @default("draft")
  duration       Int?
  maxLaps        Int?
  startedAt      DateTime?
  finishedAt     DateTime?
  syncedAt       DateTime?
  cuVersion      String?
  cuFuelMode     Boolean?
  cuRealMode     Boolean?
  cuPitLane      Boolean?
  cuLapCounter   Boolean?
  cuNumCars      Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  laps           Lap[]
  events         RaceEvent[]
  championship   Championship?   @relation(fields: [championshipId], references: [id])
  track          Track           @relation(fields: [trackId], references: [id])
  drivers        SessionDriver[]
  phases         SessionPhase[]
}

model SessionPhase {
  id         String    @id @default(cuid())
  sessionId  String
  phase      String
  status     String    @default("waiting")
  duration   Int?
  maxLaps    Int?
  startedAt  DateTime?
  pausedAt   DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, phase])
}

model SessionDriver {
  id         String  @id @default(cuid())
  sessionId  String
  driverId   String
  carId      String
  controller String
  position   Int?
  gridPos    Int?
  finalPos   Int?
  car        Car     @relation(fields: [carId], references: [id])
  driver     Driver  @relation(fields: [driverId], references: [id])
  session    Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, driverId])
  @@unique([sessionId, controller])
}

model Lap {
  id          String   @id @default(cuid())
  sessionId   String
  driverId    String
  carId       String
  controller  String
  phase       String
  lapNumber   Int
  lapTime     Float
  speed       Float?
  sector1     Float?
  sector2     Float?
  sector3     Float?
  fuelBefore  Int?
  fuelAfter   Int?
  isPitLap    Boolean  @default(false)
  pitDuration Float?
  timestamp   DateTime @default(now())
  car         Car      @relation(fields: [carId], references: [id])
  driver      Driver   @relation(fields: [driverId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, driverId])
  @@index([sessionId, lapTime])
  @@index([sessionId, phase])
}

model RaceEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  data      String
  timestamp DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}
