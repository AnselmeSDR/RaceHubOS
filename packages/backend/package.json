{
  "name": "@racehubos/backend",
  "version": "0.1.0",
  "description": "RaceHubOS Backend API and WebSocket Server",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npx prisma generate && npx prisma db push --skip-generate --accept-data-loss && node src/index.js",
    "cli": "node src/cli/sim.js",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" NODE_ENV=test jest --runInBand --passWithNoTests",
    "test:watch": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" NODE_ENV=test jest --coverage --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ink": "^6.6.0",
    "ink-text-input": "^6.0.0",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
